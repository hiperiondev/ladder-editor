' Gambas class file

Public Grid_Size As Integer = 1
Public Elements As New ClassElement[]
Public fieldMenu As Menu
Public mn As Menu
Public Element_counter As Integer = 0
Public Element_scr_counter As Integer = 0
Public PBoxItem As PictureBox
Public item As Integer
Public LastElementClick As Object = Null

Public textMenu As String[] = ["nc", "no", "output-coil", "reset-coil", "set-coil", "adder", "counter-down", "counter-up", "division", "equal-to", "greater-than-or-equal-to", "less-than-or-equal-to", "multiplication", "one-shot", "subtractor", "timer-delay-off", "timer-delay-on", "PID-controller"]
Public ElementGraphic As New Picture[]

Public Sub Form_Open()
  
  FMain.Name = "Ladder Editor"
  MenuButton1.Menu = "Ladder"
  MenuButton1.Text = "Ladder"
  
  ElementGraphic.Add(Graphic_Element(ClassElement.IxNC, "", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.IxNO, "", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.QxNO, "", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.gQx, "R", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.gQx, "S", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "ADD", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "CTD", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "CTU", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "DIV", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "=", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, ">=", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "<=", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "MUL", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.gQx, "P", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "SUB", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "TOF", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "TON", Null).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "PID", Null).Picture)
  
  FMain.Name = "Ladder Editor"
  MenuButton1.Menu = "Ladder"
  MenuButton1.Text = "Ladder"
  
  mn = New Menu(Me) As "Ladder"
  For b As Integer = 0 To textMenu.Max
    fieldMenu = New Menu(mn) As "Field"
    fieldMenu.Text = textMenu[CStr(b)]
    fieldMenu.Picture = ElementGraphic[b]
    fieldMenu.Tag = b
  Next
  
  Element_counter = 0
  Element_scr_counter = 0
  Label1.text = Str$(Element_scr_counter) & " / " & Str$(Element_counter)
  
  Panel1.Drop = True
  Panel1.Height = 640
  Panel1.Width = 1200
  Panel1.Border = 2
  
  DrawingArea1.Height = 640
  DrawingArea1.Width = 1200
  
  FMain.Height = Panel1.Height + 140
  FMain.Width = Panel1.Width + 100
  
  Grid_Size = 17
  
  Panel1.Raise
  
  'Dim fn As New String[]
  'fn.Add("iin1")
  'fn.Add("iin2")
  'fn.Add("oout1")
  'fn.Add("oout2")
  
  PBoxItem = New PictureBox(FMain) As "ElementItem"
  With PBoxItem
    .X = 13
    .Y = 50
    '.Picture = Graphic_Element(ClassElement.fgFUNCs, "NAME", fn).Picture
    .Picture = Graphic_Element(ClassElement.IxNO, "", Null).Picture
    .Height = .Picture.Height
    .Width = 51
    .Tag = "new"
  End With
  
  Drag.icon = PBoxItem.Picture
  Drag.IconX = 26
  Drag.IconY = 26
  
End

Public Sub Field_Click()
  
  PBoxItem.Picture = Last.Picture
  PBoxItem.Height = PBoxItem.Picture.Height
  Drag.icon = PBoxItem.Picture
  
End

Public Sub Panel1_DragMove()
  
  Drag.Source.Raise
  Drag.Show(Drag.Source)
  
End

Public Sub Panel1_Drop()
  
  Dim dX As Integer = Int((Round((Drag.X + Panel1.X) / Grid_Size)) * Grid_Size)
  Dim dY As Integer = Int((Round((Drag.Y + Panel1.Y) / Grid_Size)) * Grid_Size)
  
  Drag.Source.X = dX
  Drag.Source.Y = dY
  
  If LastElementClick <> Null Then
    LastElementClick.border = False
    LastElementClick.Background = Color.Transparent
  Endif
  LastElementClick = Drag.Source
  LastElementClick.border = True
  LastElementClick.Background = Color.RGB(255, 214, 153, 80)
  
  If Drag.Source.Tag = "new" Then
    Dim pb As PictureBox = PBoxItem
    
    PBoxItem = New PictureBox(FMain) As "ElementItem"
    With PBoxItem
      .X = 13
      .Y = 50
      .Alignment = 3
      .Picture = pb.Picture
      .Height = .Picture.Height
      .Width = 50
      .Raise
      .Visible = True
      .Tag = "new"
      .Show
    End With
    
    Dim Element As New ClassElement
    Element.X = dX
    Element.Y = dY
    Element.Rows = 1
    Element.eType = Element.IxNO
    Element.PBox = pb
    Element.PBox.Tag = Str$(Element_counter)
    
    Elements.Add(Element)
    Element_counter = Element_counter + 1
    Element_scr_counter = Element_scr_counter + 1
    Label1.text = Str$(Element_scr_counter) & " / " & Str$(Element_counter)
    
    If Element_counter > 2147483640 Then
      Elements_Pack()
    Endif
    
  Endif
  
End

Public Sub Form_KeyPress()
  
  If (Key.Code = Key.Up) Then LastElementClick.Y = LastElementClick.Y - Grid_Size
  If (Key.Code = Key.Down) Then LastElementClick.Y = LastElementClick.Y + Grid_Size
  If (Key.Code = Key.Left) Then LastElementClick.X = LastElementClick.X - Grid_Size
  If (Key.Code = Key.Right) Then LastElementClick.X = LastElementClick.X + Grid_Size
  
End

Public Sub DrawingArea1_Draw()
  
  For x As Integer = 25 To DrawingArea1.Width - 25 Step Grid_Size
    For y As Integer = 14 To DrawingArea1.Height - 14 Step Grid_Size
      Paint.Begin(DrawingArea1)
      With Paint
        .Brush = Paint.Color(Color.gray)
        .Arc(x, y, 1.0, Rad(0), Rad(360), False)
        .Fill
        .End
      End With 
      Paint.end
    Next
  Next
  
End

Public Sub ElementItem_MouseDown()
  
  Dim p As PictureBox
  
  If Mouse.Right = True And Last.Tag <> "new" Then
    item = Val(Last.Tag)
    MenuItem.Popup()
  Endif
  
  If Mouse.Left = True And Last.Tag <> "new" Then
    If LastElementClick <> Null Then
      LastElementClick.border = False
      LastElementClick.Background = Color.Transparent
    Endif
    LastElementClick = Last
    LastElementClick.border = True
    LastElementClick.Background = Color.RGB(255, 214, 153, 80)
  Endif
  
End

Public Sub ElementItem_MouseDrag()
  
  Last.Drag(Last.Tag)
  Drag.icon = Last.Picture
  
End

Public Sub MenuItemDelete_MouseClick()
  
  Elements[item].PBox.Delete
  Elements[item] = Null
  Element_scr_counter = Element_scr_counter - 1
  Label1.text = Str$(Element_scr_counter) & " / " & Str$(Element_counter)
  
End

Public Sub Elements_Pack()
  
  Dim Elements_new As New ClassElement[]
  Dim Element_counter_new As Integer = -1
  
  For e As Integer = 0 To Element_counter
    If Elements[e] <> Null Then
      Elements_new.Add(Elements[e])
      Element_counter_new = Element_counter_new + 1
      Elements_new[Element_counter_new].PBox.Tag = Str$(Element_counter_new)
    Endif
  Next
  
  Elements = Elements_new
  Element_counter = Element_counter_new
  Element_scr_counter = Element_counter
  Label1.text = Str$(Element_scr_counter) & " / " & Str$(Element_counter)
  
  If Element_counter > 2147483639 Then
    ErrorForm.Activate
    ErrorForm.Enabled = True
    ErrorForm.HasFocus = True
    ErrorForm.Raise
  Endif
  
End

Public Sub Graphic_Element(gType As Integer, gName As String, gPins As String[]) As Image
  
  Dim graph As Image
  
  If gpins = Null
    graph = New Image(51, 51)
  Else 
    graph = New Image(51, 51 + (17 * gPins.Count))
  Endif 
  
  graph.Fill(Color.Transparent)
  Paint.Begin(graph)
  Paint.Font = Font["Arial,8"]
  Select gType
    Case ClassElement.IxNO
      Paint.moveto(0, 26)
      Paint.LineTo(16, 26)
      Paint.moveto(32, 26)
      Paint.LineTo(51, 26)
      Paint.moveto(17, 15)
      Paint.LineTo(17, 35)
      Paint.moveto(32, 15)
      Paint.LineTo(32, 35)
    Case ClassElement.IxNC
      Paint.moveto(0, 26)
      Paint.LineTo(16, 26)
      Paint.moveto(32, 26)
      Paint.LineTo(51, 26)
      Paint.moveto(17, 15)
      Paint.LineTo(17, 35)
      Paint.moveto(32, 15)
      Paint.LineTo(32, 35)
      Paint.MoveTo(28, 15)
      Paint.LineTo(21, 35)
    Case ClassElement.QxNC
      Paint.moveto(0, 26)
      Paint.LineTo(16, 26)
      Paint.moveto(35, 26)
      Paint.LineTo(51, 26)
      Paint.moveto(16, 26)
      Paint.MoveTo(28, 15)
      Paint.LineTo(21, 35)
      Paint.Arc(26, 26, 10.0, Rad(130), Rad(100), False)
      Paint.Arc(26, 26, 10.0, Rad(310), Rad(100), False)
    Case ClassElement.QxNO
      Paint.moveto(0, 26)
      Paint.LineTo(16, 26)
      Paint.moveto(35, 26)
      Paint.LineTo(51, 26)
      Paint.moveto(16, 26)
      Paint.Arc(26, 26, 10.0, Rad(130), Rad(100), False)
      Paint.Arc(26, 26, 10.0, Rad(310), Rad(100), False)
    Case ClassElement.gQx
      Paint.Text(gName, 0, 0, 51, 51, 3)
      Paint.moveto(0, 26)
      Paint.LineTo(16, 26)
      Paint.moveto(35, 26)
      Paint.LineTo(51, 26)
      Paint.moveto(16, 26)
      Paint.Arc(26, 26, 10.0, Rad(130), Rad(100), False)
      Paint.Arc(26, 26, 10.0, Rad(310), Rad(100), False)
    Case ClassElement.fgFUNC
      Paint.Brush = Paint.Color(Color.RGB(153, 206, 255, 150))
      Paint.rectangle(5, 17, 41, 17, 5)
      Paint.Fill
      Paint.Brush = Paint.Color(Color.RGB(0, 0, 0, 0))
      Paint.rectangle(5, 17, 41, 17, 5)
      Paint.Text(gName, 0, 0, 51, 51, 3)
      Paint.moveto(0, 26)
      Paint.LineTo(5, 26)
      Paint.moveto(45, 26)
      Paint.LineTo(51, 26)
    Case ClassElement.fgFUNCs
      Dim gY As Integer
      Paint.Brush = Paint.Color(Color.RGB(153, 206, 255, 150))
      Paint.rectangle(5, 17, 41, (51 + (17 * gPins.Max)) - 10, 5)
      Paint.Fill
      Paint.Brush = Paint.Color(Color.RGB(0, 0, 0, 0))
      Paint.rectangle(5, 17, 41, (51 + (17 * gPins.Max)) - 10, 5)
      Paint.Text(gName, 0, 0, 51, 51, 3)
      Paint.moveto(0, 26)
      Paint.LineTo(5, 26)
      Paint.moveto(45, 26)
      Paint.LineTo(51, 26)
      For p As Integer = 0 To gPins.Max
        gY = 43 + (17 * p)
        If Left(gPins[p]) = "i"
          Paint.RichText(Mid(gPins[p], 2), 0, gY - 26, 51, 51, 3)
          Paint.moveto(0, gY)
          Paint.LineTo(5, gY)
        Else If Left(gPins[p]) = "o"
          Paint.RichText(Mid(gPins[p], 2), 0, gY - 26, 51, 51, 3)
          Paint.moveto(45, gY)
          Paint.LineTo(51, gY)
        End If
      Next
      
  End Select
  
  Paint.Stroke
  Paint.End 
  
  Return graph
  
End
