' Gambas class file

Public Grid_Size As Integer = 1
Public Elements As New ClassElement[]
Public fieldMenu As Menu
Public mn As Menu
Public Element_counter As Integer = 0
Public Element_scr_counter As Integer = 0
Public PBoxItem As PictureBox
Public item As Integer

Public textMenu As String[] = ["nc", "no", "output-coil", "reset-coil", "set-coil", "adder", "counter-down", "counter-up", "division", "equal-to", "greater-than-or-equal-to", "less-than-or-equal-to", "multiplication", "one-shot", "subtractor", "timer-delay-off", "timer-delay-on", "PID-controller"]
Public ElementGraphic As New Picture[]
'Public iconsMenu As String[] = ["img/nc-ladder-symbol_48.png", "img/no-symbol_48.png", "img/output-coil-symbol_48.png", "img/reset-coil-symbol_48.png", "img/set-coil-symbol_48.png", "img/adder_48.png", "img/counter-down_48.png", "img/counter-up_48.png", "img/division_48.png", "img/equal-to_48.png", "img/greater-than-or-equal-to_48.png", "img/less-than-or-equal-to_48.png", "img/multiplication_48.png", "img/one-shot-symbol_48.png", "img/subtractor_48.png", "img/timer-delay-off-symbol_48.png", "img/timer-delay-on-symbol_48.png", "img/PID-controller_48.png"]

Public Sub Form_Open()
  
  FMain.Name = "Ladder Editor"
  MenuButton1.Menu = "Ladder"
  MenuButton1.Text = "Ladder"
  
  ElementGraphic.Add(Graphic_Element(ClassElement.IxNC, "", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.IxNO, "", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.QxNO, "", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.gQx, "R", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.gQx, "S", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "ADD", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "CTD", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "CTU", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "DIV", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "=", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, ">=", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "<=", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "MUL", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.gQx, "P", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "SUB", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "TOF", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "TON", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.fgFUNC, "PID", 1).Picture)
  
  FMain.Name = "Ladder Editor"
  MenuButton1.Menu = "Ladder"
  MenuButton1.Text = "Ladder"
  
  ElementGraphic.Add(Graphic_Element(ClassElement.IxNO, "", 1).Picture)
  ElementGraphic.Add(Graphic_Element(ClassElement.IxNO, "", 1).Picture)
  
  mn = New Menu(Me) As "Ladder"
  For b As Integer = 0 To textMenu.Max
    fieldMenu = New Menu(mn) As "Field"
    fieldMenu.Text = textMenu[CStr(b)]
    'fieldMenu.Picture = Picture[iconsMenu[CStr(b)]]
    fieldMenu.Picture = ElementGraphic[b]
    fieldMenu.Tag = b
  Next
  
  Element_counter = 0
  Element_scr_counter = 0
  Label1.text = Str$(Element_scr_counter) & " / " & Str$(Element_counter)
  
  Panel1.Drop = True
  Panel1.Height = 640
  Panel1.Width = 1200
  Panel1.Border = 2
  
  DrawingArea1.Height = 640
  DrawingArea1.Width = 1200
  
  FMain.Height = Panel1.Height + 140
  FMain.Width = Panel1.Width + 100
  
  Grid_Size = 17
  Drag.icon = Picture["drop.png"]
  
  Panel1.Raise
  
  PBoxItem = New PictureBox(FMain) As "ElementItem"
  With PBoxItem
    .X = 175
    .Y = 7
    .Height = 51
    .Width = 51
    .Tag = "new"
    .Picture = Graphic_Element(ClassElement.IxNO, "", 1).Picture
  End With
  
End

Public Sub Field_Click()
  
  PBoxItem.Picture = Last.Picture
  
End

Public Sub Panel1_DragMove()
  
  Drag.Source.Raise
  Drag.Show(Drag.Source)
  
End

Public Sub Panel1_Drop()
  
  Dim dX As Integer = Int((Round((Drag.X + Panel1.X) / Grid_Size)) * Grid_Size)
  Dim dY As Integer = Int((Round((Drag.Y + Panel1.Y) / Grid_Size)) * Grid_Size)
  
  Drag.Source.X = dX
  Drag.Source.Y = dY
  
  If Drag.Source.Tag = "new" Then
    Dim pb As PictureBox = PBoxItem
    
    PBoxItem = New PictureBox(FMain) As "ElementItem"
    With PBoxItem
      .X = 175
      .Y = 7
      .Alignment = 3
      .Height = 50
      .Width = 50
      .Raise
      .Visible = True
      .Tag = "new"
      .Picture = pb.Picture
      .Show
    End With
    
    Dim Element As New ClassElement
    Element.X = dX
    Element.Y = dY
    Element.Rows = 1
    Element.eType = Element.IxNO
    Element.PBox = pb
    Element.PBox.Tag = Str$(Element_counter)
    
    Elements.Add(Element)
    Element_counter = Element_counter + 1
    Element_scr_counter = Element_scr_counter + 1
    Label1.text = Str$(Element_scr_counter) & " / " & Str$(Element_counter)
    
    If Element_counter > 2147483640 Then
      Elements_Pack()
    Endif
    
  Endif
  
End

Public Sub DrawingArea1_Draw()
  
  For x As Integer = 17 To DrawingArea1.Width - 17 Step Grid_Size
    For y As Integer = 14 To DrawingArea1.Height - 14 Step Grid_Size
      Paint.Begin(DrawingArea1)
      With Paint
        .Brush = Paint.Color(Color.gray)
        .Arc(x, y, 1.0, Rad(0), Rad(360), False)
        .Fill
        .End
      End With 
      Paint.end
    Next
  Next
  
End

Public Sub ElementItem_MouseDown()
  
  If Mouse.Right = True And Last.Tag <> "new" Then
    item = Val(Last.Tag)
    MenuItem.Popup()
  Endif
  
End

Public Sub ElementItem_MouseDrag()
  
  Last.Drag(Last.Tag)
  
End

Public Sub MenuItemDelete_Click()
  
  Elements[item].PBox.Delete
  Elements[item] = Null
  Element_scr_counter = Element_scr_counter - 1
  Label1.text = Str$(Element_scr_counter) & " / " & Str$(Element_counter)
  
End

Public Sub Elements_Pack()
  
  Dim Elements_new As New ClassElement[]
  Dim Element_counter_new As Integer = -1
  
  For e As Integer = 0 To Element_counter
    If Elements[e] <> Null Then
      Elements_new.Add(Elements[e])
      Element_counter_new = Element_counter_new + 1
      Elements_new[Element_counter_new].PBox.Tag = Str$(Element_counter_new)
    Endif
  Next
  
  Elements = Elements_new
  Element_counter = Element_counter_new
  Element_scr_counter = Element_counter
  Label1.text = Str$(Element_scr_counter) & " / " & Str$(Element_counter)
  
  If Element_counter > 2147483639 Then
    ErrorForm.Activate
    ErrorForm.Enabled = True
    ErrorForm.HasFocus = True
    ErrorForm.Raise
  Endif
  
End

Public Sub Graphic_Element(gType As Integer, gtext As String, len As Integer) As Image
  
  Dim graph As New Image(51, 51)
  
  graph.Fill(Color.Transparent)
  Paint.Begin(graph)
  Paint.Font = Font["Arial,8"]
  Select gType
    Case ClassElement.IxNO
      Paint.moveto(0, 26)
      Paint.LineTo(16, 26)
      Paint.moveto(32, 26)
      Paint.LineTo(51, 26)
      Paint.moveto(17, 15)
      Paint.LineTo(17, 35)
      Paint.moveto(32, 15)
      Paint.LineTo(32, 35)
    Case ClassElement.IxNC
      Paint.moveto(0, 26)
      Paint.LineTo(16, 26)
      Paint.moveto(32, 26)
      Paint.LineTo(51, 26)
      Paint.moveto(17, 15)
      Paint.LineTo(17, 35)
      Paint.moveto(32, 15)
      Paint.LineTo(32, 35)
      Paint.MoveTo(28, 15)
      Paint.LineTo(21, 35)
    Case ClassElement.QxNC
      Paint.moveto(0, 26)
      Paint.LineTo(16, 26)
      Paint.moveto(35, 26)
      Paint.LineTo(51, 26)
      Paint.moveto(16, 26)
      Paint.MoveTo(28, 15)
      Paint.LineTo(21, 35)
      Paint.Arc(26, 26, 10.0, Rad(130), Rad(100), False)
      Paint.Arc(26, 26, 10.0, Rad(310), Rad(100), False)
    Case ClassElement.QxNO
      Paint.moveto(0, 26)
      Paint.LineTo(16, 26)
      Paint.moveto(35, 26)
      Paint.LineTo(51, 26)
      Paint.moveto(16, 26)
      Paint.Arc(26, 26, 10.0, Rad(130), Rad(100), False)
      Paint.Arc(26, 26, 10.0, Rad(310), Rad(100), False)
    Case ClassElement.fgFUNC
      Paint.Text(gtext, 0, 0, 51, 51, 3)
      Paint.rectangle(5, 17, 41, 17, 5)
      Paint.moveto(0, 26)
      Paint.LineTo(5, 26)
      Paint.moveto(45, 26)
      Paint.LineTo(51, 26)
    Case ClassElement.gQx
      Paint.Text(gtext, 0, 0, 51, 51, 3)
      Paint.moveto(0, 26)
      Paint.LineTo(16, 26)
      Paint.moveto(35, 26)
      Paint.LineTo(51, 26)
      Paint.moveto(16, 26)
      Paint.Arc(26, 26, 10.0, Rad(130), Rad(100), False)
      Paint.Arc(26, 26, 10.0, Rad(310), Rad(100), False)
  End Select
  
  Paint.Stroke
  Paint.End 
  
  Return graph
  
End
