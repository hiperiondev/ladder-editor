' Gambas class file

Public Grid_Size As Integer = 1
Public Elements As New ClassElement[]
Public fieldMenu As Menu
Public mn As Menu
Public Element_counter As Integer = 0
Public Element_scr_counter As Integer = 0
Public PBoxItem As PictureBox
Public item As Integer
Public LastElementClick As Object = Null
Public minX As Integer
Public maxX As Integer
Public minY As Integer
Public maxY As Integer

Public textMenu1 As String[] = ["nc", "no", "output-coil", "reset-coil", "set-coil", "adder", "counter-down", "counter-up", "division", "equal-to", "greater-than-or-equal-to", "less-than-or-equal-to", "multiplication", "one-shot", "subtractor", "timer-delay-off", "timer-delay-on", "PID-controller"]
Public typeMenu1 As New Integer[]
Public rowsElement As New Integer[]
Public ElementGraphic As New Picture[]

Public Sub Form_Open()
  
  FMain.Name = "Ladder Editor"
  MenuButton1.Menu = "Ladder"
  MenuButton1.Text = "Ladder"
  
  FMain.Name = "Ladder Editor"
  MenuButton1.Menu = "Ladder"
  MenuButton1.Text = "Ladder"
  
  'Init elements
  Init_Ladder.Attributes
  
  mn = New Menu(Me) As "Ladder"
  For b As Integer = 0 To textMenu1.Max
    fieldMenu = New Menu(mn) As "Field"
    fieldMenu.Text = textMenu1[CStr(b)]
    fieldMenu.Picture = ElementGraphic[b]
    fieldMenu.Tag = b
  Next
  
  Element_counter = 0
  Element_scr_counter = 0
  Label1.text = Str$(Element_scr_counter) & " / " & Str$(Element_counter)
  
  Panel1.Drop = True
  Panel1.Height = 640
  Panel1.Width = 1200
  Panel1.Border = 2
  
  DrawingArea1.Height = Panel1.Height
  DrawingArea1.Width = Panel1.Width
  DrawingArea1.X = 0
  DrawingArea1.Y = 0
  
  FMain.Height = Panel1.Height + 140
  FMain.Width = Panel1.Width + 100
  
  Grid_Size = 17
  
  Panel1.Raise
  
  'Dim fn As New String[]
  'fn.Add("iin1")
  'fn.Add("iin2")
  'fn.Add("oout1")
  'fn.Add("oout2")
  
  PBoxItem = New PictureBox(FMain) As "ElementItem"
  With PBoxItem
    .X = 13
    .Y = 50
    '.Picture = Graphic_Element(ClassElement.fgFUNCs, "NAME", fn).Picture
    .Picture = Graphics.Element(ClassElement.IxNO, "", Null).Picture
    .Height = .Picture.Height
    .Width = 51
    .Tag = "new+" & Str$(ClassElement.IxNO)
  End With
  
  Drag.icon = PBoxItem.Picture
  Drag.IconX = 26
  Drag.IconY = 26
  
  'max/min position of elemnt
  minX = Panel1.X + 25 
  maxX = Int((Round((DrawingArea1.Width - 25 + Panel1.X) / Grid_Size)) * Grid_Size) - (4 * Grid_Size)
  minY = Panel1.Y + 14 - (26 - Grid_Size)
  maxY = Int((Round((DrawingArea1.Height - 14 + Panel1.X) / Grid_Size)) * Grid_Size) - (3 * Grid_Size)
  
End

Public Sub Field_Click()
  
  PBoxItem.Picture = Last.Picture
  PBoxItem.Height = PBoxItem.Picture.Height
  PBoxItem.Tag = "new+" & Str$(typeMenu1[Last.tag])
  Drag.icon = PBoxItem.Picture
  
End

Public Sub Panel1_DragMove()
  
  Drag.Source.Raise
  Drag.Show(Drag.Source)
  
End

Public Sub Panel1_Drop()
  
  Dim dX As Integer = Int((Round((Drag.X + Panel1.X) / Grid_Size)) * Grid_Size)
  Dim dY As Integer = Int((Round((Drag.Y + Panel1.Y) / Grid_Size)) * Grid_Size)
  
  Drag.Source.X = dX
  Drag.Source.Y = dY
  
  Try LastElementClick.Tag = LastElementClick.Tag
  If Not Error Then
    LastElementClick.border = False
    LastElementClick.Background = Color.Transparent
  Endif
  
  LastElementClick = Drag.Source
  LastElementClick.border = True
  LastElementClick.Background = Color.RGB(255, 214, 153, 80)
  
  If Mid(Drag.Source.Tag, 1, 3) = "new" Then
    Dim pb As PictureBox = PBoxItem
    
    PBoxItem = New PictureBox(FMain) As "ElementItem"
    With PBoxItem
      .X = 13
      .Y = 50
      .Alignment = 3
      .Picture = pb.Picture
      .Height = .Picture.Height
      .Width = 50
      .Raise
      .Visible = True
      .Tag = pb.tag
      .Show
    End With
    
    Dim Element As New ClassElement
    Element.X = dX
    Element.Y = dY
    Element.eType = Val(Mid(pb.Tag, 5))
    Element.Rows = rowsElement[Element.eType]
    Element.PBox = pb
    Element.PBox.Tag = Str$(Element_counter)
    
    Elements.Add(Element)
    Element_counter = Element_counter + 1
    Element_scr_counter = Element_scr_counter + 1
    Label1.text = Str$(Element_scr_counter) & " / " & Str$(Element_counter)
    
    If Element_counter > 2147483640 Then
      ClassElement.Elements_Pack()
    Endif
    
  Endif
  
End

Public Sub Form_KeyPress()
  'missing limits!
  
  If (Key.Code = Key.Up) Then LastElementClick.Y = LastElementClick.Y - Grid_Size
  If (Key.Code = Key.Down) Then LastElementClick.Y = LastElementClick.Y + Grid_Size
  If (Key.Code = Key.Left) Then LastElementClick.X = LastElementClick.X - Grid_Size
  If (Key.Code = Key.Right) Then LastElementClick.X = LastElementClick.X + Grid_Size
  
End

Public Sub DrawingArea1_Draw()
  
  For x As Integer = 25 To DrawingArea1.Width - 25 Step Grid_Size
    For y As Integer = 14 To DrawingArea1.Height - 14 Step Grid_Size
      Paint.Begin(DrawingArea1)
      With Paint
        .Brush = Paint.Color(Color.gray)
        .Arc(x, y, 1.0, Rad(0), Rad(360), False)
        .Fill
        .End
      End With 
      Paint.end
    Next
  Next
  
End

Public Sub ElementItem_MouseDown()
  
  If Mid(Last.Tag, 1, 3) <> "new" Then
    item = Val(Last.Tag)
  Endif 
  
  If Mouse.Right = True And Mid(Last.Tag, 1, 3) <> "new" Then
    MenuPopUPItem.Popup()
  Endif
  
  Try Last.Tag = Last.Tag
  If Error Then
    Return
  Endif
  
  If Mid(Last.Tag, 1, 3) <> "new" And Mouse.Left = True Then
    Try LastElementClick.Tag = LastElementClick.Tag
    If Not Error Then
      If LastElementClick <> Null Then
        LastElementClick.border = False
        LastElementClick.Background = Color.Transparent
      Endif
    Endif 
    LastElementClick = Last
    LastElementClick.border = True
    LastElementClick.Background = Color.RGB(255, 214, 153, 80)
  Endif
  
End

Public Sub ElementItem_MouseDrag()
  
  Last.Drag(Last.Tag)
  Drag.icon = Last.Picture 
  
End

Public Sub MenuItemDelete_Click()
  
  Elements[item].PBox.Delete
  Elements[item] = Null
  Element_scr_counter = Element_scr_counter - 1
  Label1.text = Str$(Element_scr_counter) & " / " & Str$(Element_counter)
  
End