      Text = ("Export XML")
      Picture = Picture["icon:/32/xml"]
    }
    { text Menu
      Text = ("Export TEXT")
      Picture = Picture["icon:/32/csv"]
    }
  }
  { MenuItem Menu
    Text = ("MenuItem")
    Visible = False
    { MenuItemDelete Menu
      Text = ("Delete")
      Picture = Picture["icon:/32/delete"]
    }
    { MenuItem_Properties Menu
      Text = ("Properties")
      Picture = Picture["icon:/32/properties"]
    }
  }
  { MenuButton1 MenuButton
