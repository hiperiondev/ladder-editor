# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,73,49)
  { MenuFile Menu
    Text = ("File")
    { Load Menu
      Text = ("Load")
      Picture = Picture["icon:/32/open"]
    }
    { Save Menu
      Text = ("Save")
      Picture = Picture["icon:/32/save"]
    }
    { MenuProperties Menu
      Text = ("Properties")
      Picture = Picture["icon:/32/properties"]
    }
  }
  { MenuCompile Menu
    Text = ("Compile")
